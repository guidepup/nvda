complexSymbols:
# identifier	regexp
# Sentence endings.
. sentence ending	(?<=[^\s.])\.(?=[\"'‚Äù‚Äô)\s]|$)
! sentence ending	(?<=[^\s!])\!(?=[\"'‚Äù‚Äô)\s]|$)
? sentence ending	(?<=[^\s?])\?(?=[\"'‚Äù‚Äô)\s]|$)
# Phrase endings.
; phrase ending	(?<=[^\s;]);(?=\s|$)
: phrase ending	(?<=[^\s:]):(?=\s|$)
# Series of dots used for visual presentation, e.g. in table of contents
multiple .	\.{4,}
# Others
decimal point	(?<![^\d -])\.(?=\d)
in-word '	(?<=[^\W_])['‚Äô]
negative number	(?<!\w)[-‚àí]{1}(?=[$¬£‚Ç¨¬•.]?\d)

